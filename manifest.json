{
  "manifest_version": 3,
  "name": "Cineville Ratings",
  "version": "1.0.0",
  "description": "Shows Letterboxd and IMDb ratings on cineville.nl showtimes and film pages.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://cineville.nl/*",
    "https://letterboxd.com/*",
    "https://www.omdbapi.com/*",
    "https://api.themoviedb.org/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cineville.nl/*"],
      "js": ["src/content.js"],
      "css": ["src/styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "src/popup.html",
  "action": {
    "default_title": "Cineville Ratings",
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
